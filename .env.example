# Example environment variables (do NOT commit real secrets)
# Copy to .env and fill OPENAI_API_KEY for personal use or map these into env.js in your build.

# OpenAI
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# Limits and timeouts
TIMEOUT_MS=30000
# ~2000 tokens total input ≈ 8000 chars
INPUT_CHAR_LIMIT=8000
# Split input budget (0..1): 60% job description, 40% template
INPUT_JOB_RATIO=0.6
# Max output tokens from the model
MAX_TOKENS=400

# Sampling knobs (used for non-GPT-5 chat completions)
TEMPERATURE=0.5
TOP_P=1
PRESENCE_PENALTY=0
FREQUENCY_PENALTY=0

# GPT-5 Responses API reasoning effort: none | low | medium | high
REASONING_EFFORT=none