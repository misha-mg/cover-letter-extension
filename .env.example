# This extension reads settings from src/config/env.js (see env.example.js in the repo root).
# The variables below are documentation only; they are not loaded by the extension at runtime.
#
# Copy env.example.js → src/config/env.js and set:
#
#   OPENROUTER_API_KEY   — required (https://openrouter.ai)
#   OPENROUTER_MODEL     — e.g. openai/gpt-4o-mini, anthropic/claude-3.5-sonnet
#   OPENROUTER_API_BASE  — default https://openrouter.ai/api/v1
#   OPENROUTER_REFERER   — optional, sent as HTTP-Referer to OpenRouter
#   OPENROUTER_TITLE     — optional, sent as X-Title to OpenRouter
#   TIMEOUT_MS, MAX_TOKENS, TEMPERATURE — optional tuning

OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
TIMEOUT_MS=30000
MAX_TOKENS=15000
TEMPERATURE=0.5
