{
  "name": "cover-extension",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:openrouter",
    "build:openrouter": "esbuild src/api/openrouter.js --bundle --format=esm --platform=browser --outfile=dist/openrouter.bundle.js --external:chrome",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "format": "prettier --write .",
    "check": "npm run lint && prettier --check ."
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^1.2.3",
    "ai": "^5.0.104"
  },
  "devDependencies": {
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "esbuild": "^0.24.0",
    "prettier": "^3.3.3"
  }
}
